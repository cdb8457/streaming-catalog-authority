# Point at any PostgreSQL 16.
#
# ADMIN_DATABASE_URL is the OWNER/migrator role: it runs migrations, owns the
# tables and the append-only triggers, and creates the runtime role. Keep it out
# of the application runtime.
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalog

# DATABASE_URL is the least-privileged runtime role the authority uses. It can
# append+read events and mutate the projection, but cannot UPDATE/DELETE/TRUNCATE
# events or disable the triggers.
DATABASE_URL=postgresql://app:app@localhost:5432/catalog

# If neither is set, `npm test` boots an embedded PostgreSQL 16 automatically.

# --- Configuration validation (Phase 3 Stage 3.1) ---------------------------
# Config is loaded + validated centrally (src/config/env.ts), failing fast and
# reporting EVERY problem at once. Error messages reference variable NAMES only,
# never their values, so a connection string's password cannot leak into logs.
#
# Required: DATABASE_URL (the runtime role). ADMIN_DATABASE_URL is optional and
# falls back to DATABASE_URL for a single-role dev setup (production should keep
# them distinct).
#
# Secret-file indirection (Docker / Unraid secrets): for any variable NAME you may
# instead set NAME_FILE to a file path; the value is read from that file (a single
# trailing newline is stripped). Setting both NAME and NAME_FILE is rejected.
#   DATABASE_URL_FILE=/run/secrets/database_url
#   ADMIN_DATABASE_URL_FILE=/run/secrets/admin_database_url
#
# --- Key custodian selection (Phase 3 Stage 3.2) ----------------------------
# createCustodian()/custodianFromEnv() (src/core/crypto/custodian-factory.ts) turn
# validated config into a KeyCustodian. The system depends only on the interface, so
# swapping the production custodian is a config change. Unknown modes FAIL CLOSED.
#
# CUSTODIAN_MODE: memory | file        (required)
#   memory = in-process dev/test custodian; file = FileCustodian reference harness.
#   PRODUCTION GUARD (Phase 4): memory is REFUSED when APP_ENV (or NODE_ENV) = production.
#   Override only with the exact value CUSTODIAN_ALLOW_INSECURE_MEMORY=true (NOT recommended).
# APP_ENV: production | development | test  (optional; falls back to NODE_ENV, default development).
# APP_ENV=production
# COMPLETION_SECRET (or COMPLETION_SECRET_FILE): the HMAC attestation secret shared
#   out-of-band with the DB (crypto_config). Required for all modes.
CUSTODIAN_MODE=memory
COMPLETION_SECRET=change-me-shared-with-the-database
#
# For CUSTODIAN_MODE=file, also set:
#   CUSTODIAN_KEYSTORE_DIR  keystore root (keep on a volume separate from DB backups)
#   CUSTODIAN_KEK (or CUSTODIAN_KEK_FILE)  base64-encoded 32-byte key-encryption key
# CUSTODIAN_KEYSTORE_DIR=/var/lib/catalog/keystore
# CUSTODIAN_KEK_FILE=/run/secrets/custodian_kek
#
# KEK ROTATION (Phase 4 Stage 4.2): `npm run ops:rewrap-kek` re-wraps every live DEK from the
# previous KEK to the new one (identity ciphertext untouched; resumable + idempotent; run with the
# app quiesced). Set CUSTODIAN_KEK to the NEW key and CUSTODIAN_KEK_PREVIOUS to the OLD key (both
# base64 32 bytes; _FILE variants supported). CUSTODIAN_KEK_PREVIOUS is read ONLY by this rotation
# step — remove it from the runtime config afterward.
# CUSTODIAN_KEK_PREVIOUS_FILE=/run/secrets/custodian_kek_previous
#
# Reference harnesses only. The managed-KMS adapter (design O4) is still an open
# production deployment gate and would add another CUSTODIAN_MODE here. The age-encrypted-file
# KEK is operator-side (decrypt to base64 before mounting as CUSTODIAN_KEK[_FILE]); no in-process
# age integration is bundled.

# --- Provider adapter boundary (Phase 7) ------------------------------------
# ADAPTER_MODE: fake | none (default none = no adapter configured). Unknown values FAIL CLOSED.
# Phase 7 ships only a LOCAL fake ref-resolver — no real providers, no network. Adapters receive
# ONLY an opaque itemId + one scoped { refType, refValue } (never catalog identity) via
# CatalogAuthority.withProviderRef(), and their output is advisory (never written to the event log).
# ADAPTER_MODE=none

# --- Publisher adapter boundary (Phase 8) -----------------------------------
# PUBLISHER_MODE: fake | none (default none = no publisher; identity never crosses the boundary).
# Unknown values FAIL CLOSED. Phase 8 ships only a LOCAL fake publisher — no real Plex/Jellyfin, no
# network, no credentials. A publisher receives only its DECLARED minimized fields (title/year/
# providerRefs — never externalIds/metadata/ciphertext) via CatalogAuthority.withPublishableIdentity(),
# dry-run is the default, and output is advisory (never persisted). Real external publishing is a
# deferred policy gate (it conflicts with crypto-shredding). See docs/PHASE_8_PUBLISHER_BOUNDARY.md.
# PUBLISHER_MODE=none

# --- External-publish consent gate (Phase 9) --------------------------------
# PUBLISH_EXTERNAL_IDENTITY: allow | (unset/anything else = DENY, fail-closed). A LIVE publish sends
# minimized identity OUTSIDE the crypto-shredding boundary (a copy that forget cannot reach), so it
# is refused unless this is explicitly `allow`. A dry-run is always allowed. Live publishes are
# recorded in the IDENTITY-FREE publish_ledger (opaque item id + target + opaque handle + disclosed
# field NAMES only); on forget, ops:publish-reconcile queues those rows for best-effort revocation.
# See docs/PHASE_9_ERASURE_POLICY.md.
# PUBLISH_EXTERNAL_IDENTITY=deny

# --- Jellyfin publisher adapter (Phase 10 — fake/local only) -----------------
# Jellyfin does COLLECTION CURATION keyed on provider refs (title names the collection; providerRefs
# resolve library items). Phase 10 ships ONLY a local fake client + config PARSER/REDACTION scaffolding
# — it constructs NO network client (the real HTTP client is Phase 11). These vars are parsed/validated
# and the api key is redaction-safe (registered with the SecretStore; never logged or written to the
# ledger). A live publish still requires PUBLISH_EXTERNAL_IDENTITY=allow (Phase 9). See
# docs/PHASE_10_JELLYFIN_ADAPTER.md.
# JELLYFIN_BASE_URL=http://jellyfin.local:8096
# JELLYFIN_API_KEY_FILE=/run/secrets/jellyfin_api_key
# JELLYFIN_USER_ID=
#
# Phase 11 — REAL Jellyfin HTTP client (gated, default OFF). Two independent switches are required
# for a LIVE real publish: (1) JELLYFIN_ENABLE_NETWORK=true (default off — no real HTTP otherwise),
# AND (2) PUBLISH_EXTERNAL_IDENTITY=allow (Phase 9 consent). The real client uses platform fetch
# (injected; no new dep) and is NEVER exercised in automated tests. Optional JELLYFIN_TIMEOUT_MS sets
# the per-request timeout (ms). Endpoint mapping is PROVISIONAL — validate with `npm run smoke:jellyfin`
# (opt-in, requires a real server) before trusting real publishing. See docs/PHASE_11_JELLYFIN_HTTP.md.
# JELLYFIN_ENABLE_NETWORK=false
# JELLYFIN_TIMEOUT_MS=10000
#
# JELLYFIN_ALLOW_LIVE_PUBLISH (default off): a SEPARATE switch gating the non-idempotent collection
# CREATE. Real create stays refused (fail-closed) until you set this AND have validated create/delete
# with smoke:jellyfin. With it OFF, orphaning is impossible (no create happens). When ON, an ambiguous
# create (no id / dropped connection) is cleaned up + verified; if cleanup cannot be confirmed it fails
# LOUDLY (JellyfinOrphanError) flagging a possible orphan for manual reconciliation — the residual risk
# under sustained network failure is why this is gated + smoke-validated. (find + revoke/delete work without it.)
# JELLYFIN_ALLOW_LIVE_PUBLISH=false

# --- Deployment (Phase 3 Stage 3.4) -----------------------------------------
# docker-compose.deploy.yml runs Postgres + on-demand ops/CLI containers (no HTTP).
# All secrets are delivered as files and read via the *_FILE indirection above; the
# custodian keystore lives on a volume SEPARATE from the Postgres data so DB backups
# never contain key material. KEK age-decryption is operator-side (mount the decrypted
# base64 KEK as CUSTODIAN_KEK_FILE). See docs/PHASE_3_DEPLOYMENT.md (incl. Unraid notes).
#   npm run ops:migrate          # apply schema (owner)
#   npm run ops:doctor [-- --json]  # read-only self-check (JSON contract for unattended cron)
#   npm run ops:version          # db schema version vs this build
#   npm run ops:backup -- dump <file> / restore <file>
#   npm run ops:verify-backup -- <file>   # offline structural check (no DB)
#   npm run ops:rewrap-kek       # KEK rotation
#   npm run smoke:compose        # opt-in/manual; requires Docker (not run in CI)
#
# Restore rehearsal (Phase 6): REHEARSAL_ADMIN_DATABASE_URL must point at a SEPARATE throwaway
# database (never production) — the rehearsal migrates + restores + reads there and HARD-refuses if
# it resolves to the production DB (same host:port/dbname as ADMIN_DATABASE_URL or DATABASE_URL).
# REHEARSAL_ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalog_rehearsal
#   npm run ops:rehearse-restore -- <file>
